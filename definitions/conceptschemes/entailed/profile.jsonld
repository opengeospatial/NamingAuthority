      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@value": "return DGGS-JSON-FG representation; using dggsPlace to encode geometry points quantized to sub-zone; represented as local indices from 1 to the number of sub-zones corresponding to the DGGRS deterministic sub-zone order; with a special value of 0 representing an artificial node"
      }
    ],
