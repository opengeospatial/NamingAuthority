    ns1:status <http://www.opengis.net/def/status/valid> ;
    skos:definition "return CoverageJSON where one axis corresponds to the global identifiers of sub-zones (textual or 64-bit integer)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "covjson-dggs-zoneids profile of DGGS zone data" ;
    skos:topConceptOf <https://www.opengis.net/def/profile> .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs> a skos:Concept ;
    rdfs:label "jsonfg-dggs profile of DGGS zone data" ;
    dcterms:created "2026-06-04T16:36:40.357731"^^xsd:dateTime ;
    ns1:status <http://www.opengis.net/def/status/valid> ;
    skos:definition "return DGGS-JSON-FG representation; using dggsPlace to encode geometry points quantized to sub-zone; represented as local indices from 1 to the number of sub-zones corresponding to the DGGRS deterministic sub-zone order; with a special value of 0 representing an artificial node" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-dggs profile of DGGS zone data" ;
    skos:topConceptOf <https://www.opengis.net/def/profile> .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs-plus> a skos:Concept ;
    rdfs:label "jsonfg-dggs-plus profile of DGGS zone data" ;
