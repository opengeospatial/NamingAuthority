<https://www.opengis.net/def/profile/ogc/0/covjson> a skos:Concept ;
    rdfs:label "covjson profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366798"^^xsd:dateTime ;
    skos:definition "return CoverageJSON (not quantized to DGGH)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "covjson profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/covjson-dggs> a skos:Concept ;
    rdfs:label "covjson-dggs profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366849"^^xsd:dateTime ;
    skos:definition "return CoverageJSON where one axis corresponds to local sub-zone indices" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "covjson-dggs profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/covjson-dggs-zoneids> a skos:Concept ;
    rdfs:label "covjson-dggs-zoneids profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366899"^^xsd:dateTime ;
    skos:definition "return CoverageJSON where one axis corresponds to the global identifiers of sub-zones (textual or 64-bit integer)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "covjson-dggs-zoneids profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg> a skos:Concept ;
    rdfs:label "jsonfg profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.365932"^^xsd:dateTime ;
    skos:definition "return JSON-FG representation" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs> a skos:Concept ;
    rdfs:label "jsonfg-dggs profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366039"^^xsd:dateTime ;
    skos:definition "return DGGS-JSON-FG representation; using dggsPlace to encode geometry points quantized to sub-zone; represented as local indices from 1 to the number of sub-zones corresponding to the DGGRS deterministic sub-zone order; with a special value of 0 representing an artificial node" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-dggs profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs-plus> a skos:Concept ;
    rdfs:label "jsonfg-dggs-plus profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366096"^^xsd:dateTime ;
    skos:definition "return DGGS-JSON-FG representation; with GeoJSON compatibility geometry" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-dggs-plus profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs-zoneids> a skos:Concept ;
    rdfs:label "jsonfg-dggs-zoneids profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366144"^^xsd:dateTime ;
    skos:definition "return DGGS-JSON-FG representation; using dggsPlace to encode geometry points as textual global zone identifiers; with a special value of null representing an artificial node" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-dggs-zoneids profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-dggs-zoneids-plus> a skos:Concept ;
    rdfs:label "jsonfg-dggs-zoneids-plus profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366190"^^xsd:dateTime ;
    skos:definition "return DGGS-JSON-FG representation; encoding geometry points as global zone IDs; with GeoJSON compatibility geometry" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-dggs-zoneids-plus profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/jsonfg-plus> a skos:Concept ;
    rdfs:label "jsonfg-plus profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.365990"^^xsd:dateTime ;
    skos:definition "return JSON-FG representation with GeoJSON compatibility" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "jsonfg-plus profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf3> a skos:Concept ;
    rdfs:label "netcdf3 profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366238"^^xsd:dateTime ;
    skos:definition "return NetCDF classic and 64-bit offset format (not quantized to DGGH)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf3 profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf3-dggs> a skos:Concept ;
    rdfs:label "netcdf3-dggs profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366284"^^xsd:dateTime ;
    skos:definition "return NetCDF classic and 64-bit offset format where one axis corresponds to local sub-zone indices" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf3-dggs profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf3-dggs-zoneids> a skos:Concept ;
    rdfs:label "netcdf3-dggs-zoneids profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366331"^^xsd:dateTime ;
    skos:definition "return NetCDF classic and 64-bit offset format where one axis corresponds to the global identifiers of sub-zones (textual or 64-bit integer)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf3-dggs-zoneids profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf4> a skos:Concept ;
    rdfs:label "netcdf4 profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366382"^^xsd:dateTime ;
    skos:definition "return HFG5-based NetCDF 4 format (not quantized to DGGH)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf4 profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf4-dggs> a skos:Concept ;
    rdfs:label "netcdf4-dggs profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366433"^^xsd:dateTime ;
    skos:definition "return HDF5-based NetCDF 4 format where one axis corresponds to local sub-zone indices" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf4-dggs profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/netcdf4-dggs-zoneids> a skos:Concept ;
    rdfs:label "netcdf4-dggs-zoneids profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366486"^^xsd:dateTime ;
    skos:definition "return HDF5-based NetCDF 4 format where one axis corresponds to the global identifiers of sub-zones (textual or 64-bit integer)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "netcdf4-dggs-zoneids profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/rfc7946> a skos:Concept ;
    rdfs:label "rfc7946 profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.365864"^^xsd:dateTime ;
    skos:definition "return standard GeoJSON without using any extension" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "rfc7946 profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/zarr2> a skos:Concept ;
    rdfs:label "zarr2 profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366660"^^xsd:dateTime ;
    skos:definition "return zipped Zarr 2.0 (not quantized to DGGH)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "zarr2 profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/zarr2-dggs> a skos:Concept ;
    rdfs:label "zarr2-dggs profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366708"^^xsd:dateTime ;
    skos:definition "return zipped Zarr 2.0 where one axis corresponds to local sub-zone indices" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "zarr2-dggs profile of DGGS zone data" .

<https://www.opengis.net/def/profile/ogc/0/zarr2-dggs-zoneids> a skos:Concept ;
    rdfs:label "zarr2-dggs-zoneids profile of DGGS zone data" ;
    dcterms:created "2026-05-18T19:44:18.366753"^^xsd:dateTime ;
    skos:definition "return zipped Zarr 2.0 where one axis corresponds to the global identifiers of sub-zones (textual or 64-bit integer)" ;
    skos:inScheme <https://www.opengis.net/def/profile> ;
    skos:prefLabel "zarr2-dggs-zoneids profile of DGGS zone data" .

